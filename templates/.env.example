DATABASE_URL="file:./prisma/dev.db"
DISCORD_TOKEN="YOUR_DISCORD_TOKEN"
JULES_API_KEY="YOUR_JULES_API_KEY"

# Logging verbosity: debug | info | warn | error (default: info).
# `npm run dev` forces debug; production (npm start / pm2) defaults to info.
LOG_LEVEL="info"

# Access Controls
ALLOW_ALL="true" # Set to "false" to enforce allowlisting
ALLOWED_USERS="123456789012345678,987654321098765432" # Comma-separated Discord User IDs
ALLOWED_ROLES="112233445566778899" # Comma-separated Discord Role IDs

# Optional: register slash commands instantly to a single guild (dev/test).
# Leave unset for global registration (can take up to ~1 hour to propagate).
# DEV_GUILD_ID=""

# Optional: expose a JSON liveness endpoint (GET /health) for Docker/uptime
# monitors. Unset = disabled. (Docker Compose sets this to 3000.)
# HEALTHCHECK_PORT="3000"
