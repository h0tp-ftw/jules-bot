{
  "name": "jules-bot",
  "version": "1.0.0",
  "description": "A Discord bot that turns forum threads into interactive Google Jules coding-agent sessions — diagnose first, change only on human approval.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && LOG_LEVEL=debug tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "node scripts/setup.js",
    "doctor": "node scripts/doctor.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "lint": "eslint .",
    "format": "prettier --write \"{src,scripts,test}/**/*.{ts,js}\" eslint.config.js",
    "format:check": "prettier --check \"{src,scripts,test}/**/*.{ts,js}\" eslint.config.js",
    "test": "node --import tsx --test test/messageSplitter.test.ts test/emojis.test.ts test/attachments.test.ts test/strings.test.ts test/sessionState.test.ts test/errors.test.ts test/invite.test.ts test/logger.test.ts test/permissions.test.ts test/config.test.ts"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "discord.js",
    "google-jules",
    "jules",
    "ai-agent",
    "coding-agent",
    "typescript"
  ],
  "author": "h0tp-ftw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h0tp-ftw/jules-bot.git"
  },
  "bugs": {
    "url": "https://github.com/h0tp-ftw/jules-bot/issues"
  },
  "homepage": "https://github.com/h0tp-ftw/jules-bot#readme",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "dependencies": {
    "@google/jules-sdk": "^0.2.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "pm2": "^7.0.3",
    "prisma": "^7.8.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
